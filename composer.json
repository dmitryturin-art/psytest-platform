{
  "name": "psytest/platform",
  "description": "Modular web service for psychological testing",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "twig/twig": "^3.0",
    "dompdf/dompdf": "^3.0",
    "ramsey/uuid": "^4.7",
    "monolog/monolog": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.54",
    "robmorgan/phinx": "^0.16"
  },
  "autoload": {
    "psr-4": {
      "PsyTest\\Core\\": "core/",
      "PsyTest\\Services\\": "services/",
      "PsyTest\\Modules\\": "modules/",
      "PsyTest\\Controllers\\": "controllers/",
      "PsyTest\\Modules\\Smil\\": "modules/smil/",
      "PsyTest\\Modules\\BeckAnxiety\\": "modules/beck-anxiety/",
      "PsyTest\\Modules\\BeckDepression\\": "modules/beck-depression/",
      "PsyTest\\Modules\\Hads\\": "modules/hads/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PsyTest\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse core controllers services modules --level=6 --memory-limit=512M",
    "lint": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
    "lint:fix": "php-cs-fixer fix --allow-risky=yes",
    "migrate": "phinx migrate",
    "migrate:create": "phinx create",
    "post-install-cmd": [
      "chmod +x bin/cleanup-sessions.php 2>/dev/null || true"
    ]
  }
}

{% set invite_link = appUrl ~ '/test/' ~ test.slug ~ '/pair?partner=' ~ session.session_token %}
<div class="pair-invite-block">
    <p class="pair-invite__text">
        Хотите сравнить ваши ответы с ответами партнёра? Отправьте ему эту ссылку —
        когда партнёр пройдёт тест, здесь автоматически появится сравнение.
    </p>
    <div class="pair-invite__link-box">
        <input type="text" id="pairInviteLink" class="pair-invite__input" readonly
               value="{{ invite_link }}" onclick="this.select()">
        <button type="button" class="btn btn-primary" onclick="copyPairLink(this)">Копировать</button>
    </div>
    <p class="pair-invite__hint">
        Ссылку можно отправить любым удобным способом — в мессенджере, по email и т.п.
    </p>
</div>
<script>
function copyPairLink(btn) {
    const input = document.getElementById('pairInviteLink');
    navigator.clipboard.writeText(input.value).then(function () {
        const original = btn.textContent;
        btn.textContent = '✓ Скопировано';
        setTimeout(function () { btn.textContent = original; }, 2000);
    });
}
</script>

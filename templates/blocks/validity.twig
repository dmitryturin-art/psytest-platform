<div class="validity-block">
    <div class="validity-grid">
        <div class="validity-item {{ is_valid ? 'valid' : 'invalid' }}">
            <span class="validity-label">L (ложь)</span>
            <span class="validity-value">{{ L_score }}</span>
        </div>
        <div class="validity-item">
            <span class="validity-label">F (достоверность)</span>
            <span class="validity-value">{{ F_score }}</span>
        </div>
        <div class="validity-item">
            <span class="validity-label">K (коррекция)</span>
            <span class="validity-value">{{ K_score }}</span>
        </div>
        <div class="validity-item">
            <span class="validity-label">? (не знаю)</span>
            <span class="validity-value">{{ unknown_count }}</span>
        </div>
        <div class="validity-item">
            <span class="validity-label">QC (контроль)</span>
            <span class="validity-value">{{ control_score }}/27</span>
        </div>
        <div class="validity-item">
            <span class="validity-label">F-K индекс</span>
            <span class="validity-value">{{ FK_index }}</span>
        </div>
    </div>
    {% if warnings is not empty %}
    <div class="validity-warnings">
        {% for w in warnings %}<p class="warning">{{ w }}</p>{% endfor %}
    </div>
    {% endif %}
    <p class="validity-status {{ is_valid ? 'valid' : 'invalid' }}">
        {{ is_valid ? '✓ Протокол достоверен' : '⚠ Протокол недостоверен' }}
    </p>
</div>

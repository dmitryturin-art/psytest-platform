<div class="interpretation-block">
    <h3>Интерпретация шкал</h3>
    {% for s in scales %}
    <div class="interpretation-item interpretation-item--{{ s.level }}">
        <h4 class="interpretation-item__code">{{ s.code }} — {{ s.name }}</h4>
        <p class="interpretation-item__text">{{ s.text }}</p>
    </div>
    {% endfor %}
</div>
